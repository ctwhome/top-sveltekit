# SurrealDB Configuration
SURREAL_URL=wss://surreal.ctwhome.com/rpc
SURREAL_NS=test
SURREAL_DB=testdb
SURREAL_USER=root
SURREAL_PASS=root

# Auth.js Configuration
AUTH_SECRET= # Run `openssl rand -base64 32` to generate a secret
GOOGLE_CLIENT_ID= # Get from Google Cloud Console
GOOGLE_CLIENT_SECRET= # Get from Google Cloud Console

# Resend API key
AUTH_RESEND_KEY=re_...

# Note: To set up Google OAuth:
# 1. Go to Google Cloud Console (https://console.cloud.google.com)
# 2. Create a new project or select existing one
# 3. Enable Google+ API
# 4. Go to Credentials -> Create Credentials -> OAuth Client ID
# 5. Set up OAuth consent screen if not done
# 6. Create Web Application type credentials
# 7. Add authorized redirect URI: http://localhost:5173/auth/callback/google (for development)
#    and your production URL: https://yourdomain.com/auth/callback/google
# 8. Copy Client ID and Client Secret to this file
