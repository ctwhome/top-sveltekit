# SurrealDB Configuration
SURREAL_URL=wss://surreal.ctwhome.com/rpc
SURREAL_NS=test
SURREAL_DB=testdb
SURREAL_USER=root
SURREAL_PASS=root

# Auth.js Configuration
# Run `openssl rand -base64 32` to generate a secret
# This secret will be used for both AuthJS JWT and SurrealDB token encryption
AUTH_SECRET= # Required: Used for JWT signing and encryption
AUTH_TRUST_HOST=true # Required for production: Ensures secure cookie handling
AUTH_URL=http://localhost:5173 # Required: Your application URL (in development)

# Session Configuration
AUTH_SESSION_MAX_AGE=86400 # Optional: Session duration in seconds (default 24 hours)
AUTH_SESSION_UPDATE_AGE=3600 # Optional: How frequently to update session (default 1 hour)

# OAuth Providers
GOOGLE_CLIENT_ID= # Get from Google Cloud Console
GOOGLE_CLIENT_SECRET= # Get from Google Cloud Console

# Resend API key (if using magic links)
AUTH_RESEND_KEY=re_...

# Note: To set up Google OAuth:
# 1. Go to Google Cloud Console (https://console.cloud.google.com)
# 2. Create a new project or select existing one
# 3. Enable Google+ API
# 4. Go to Credentials -> Create Credentials -> OAuth Client ID
# 5. Set up OAuth consent screen if not done
# 6. Create Web Application type credentials
# 7. Add authorized redirect URI: http://localhost:5173/auth/callback/google (for development)
#    and your production URL: https://yourdomain.com/auth/callback/google
# 8. Copy Client ID and Client Secret to this file

# Production Configuration:
# - Change AUTH_URL to your production URL
# - Set AUTH_TRUST_HOST=true
# - Use a strong AUTH_SECRET
# - Configure secure cookie settings
# - Update OAuth redirect URIs in Google Console
