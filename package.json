{
  "name": "top-sveltekit",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "package": "npm run build && electron-builder --config electron-builder.config.json",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --ignore-path .gitignore --check --plugin-search-dir=. . && eslint --ignore-path .gitignore .",
    "format": "prettier --ignore-path .gitignore --write --plugin-search-dir=. .",
    "electron": "concurrently --kill-others \"vite dev\" \"electron src/electron.cjs\"",
    "dev:package": "npm run build && electron-builder --config electron-builder.config.json --dir"
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.4.2",
    "@popperjs/core": "^2.11.8",
    "@sveltejs/adapter-vercel": "^3.0.1",
    "@sveltejs/kit": "^1.20.4",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.9",
    "@types/cookie": "^0.5.1",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "autoprefixer": "^10.4.14",
    "classnames": "^2.3.2",
    "concurrently": "^8.2.0",
    "electron-builder": "^24.4.0",
    "electron-reloader": "^1.2.3",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-svelte3": "^4.0.0",
    "mdsvex": "^0.10.6",
    "nprogress": "^0.2.0",
    "prettier": "^2.8.8",
    "prettier-plugin-svelte": "^2.10.1",
    "svelte": "^4.0.0",
    "svelte-check": "^3.4.4",
    "svelte-heros": "^3.12.1",
    "svelte-preprocess": "^5.0.4",
    "tailwindcss": "^3.3.2",
    "tslib": "^2.5.3",
    "typescript": "~5.1.3",
    "vite": "^4.3.9"
  },
  "type": "module",
  "dependencies": {
    "@fontsource/fira-mono": "^5.0.3",
    "@lukeed/uuid": "^2.0.1",
    "@poppanator/sveltekit-svg": "^3.0.1",
    "@supabase/supabase-js": "^2.26.0",
    "cookie": "^0.5.0",
    "daisyui": "^3.1.5",
    "electron": "^25.2.0",
    "electron-serve": "^1.1.0",
    "electron-window-state": "^5.0.3",
    "idb": "^7.1.1",
    "theme-change": "^2.5.0",
    "@tiptap/core": "2.0.3",
    "@tiptap/extension-link": "2.0.3",
    "@tiptap/extension-placeholder": "2.0.3",
    "@tiptap/extension-task-item": "2.0.3",
    "@tiptap/extension-task-list": "2.0.3",
    "@tiptap/extension-youtube": "2.0.3",
    "@tiptap/starter-kit": "2.0.3"
  }
}
